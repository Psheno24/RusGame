# === Локально (два терминала dev:api + dev:web) ===
PORT=3001
LOCAL_DEV=true
JWT_SECRET=local-dev-secret
COOKIE_SECURE=false
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123

# Тест-аккаунт (создаётся автоматически при LOCAL_DEV=true)
TEST_LOGIN=tester
TEST_PASSWORD=test123456
TEST_COOLDOWN_SEC=10

# === Production на VPS (docker compose) ===
# SITE_DOMAIN=game.ваш-домен.ru
#   Для www.${SITE_DOMAIN} добавьте A-запись на тот же IP — Caddy перенаправит на основной домен.
# SITE_BIND_IP=185.x.x.x
#   IP, на котором слушает игра (80/443). Нужен, если Xray/VPN уже занял 443 на другом IP сервера.
#   DNS домена (A-запись) должен указывать на SITE_BIND_IP.
# LOCAL_DEV=false
# ENABLE_TEST_ACCOUNT=true
# TEST_LOGIN=tester
# TEST_PASSWORD=свой-надёжный-пароль
# TEST_COOLDOWN_SEC=10
# JWT_SECRET=сгенерируйте-openssl-rand-base64-32
# COOKIE_SECURE=true
# TRUST_PROXY=true
# ADMIN_PASSWORD=надёжный-пароль
#
# Push-уведомления (PWA). Сгенерировать один раз на сервере:
#   cd /opt/rusgame && npx web-push generate-vapid-keys
# Скопируйте Public Key и Private Key в строки ниже.
# VAPID_SUBJECT — ваш email (требование протокола Web Push, письма не шлёт).
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:ваш@email.ru
#
# Push-уведомления (PWA). Сгенерировать один раз на сервере:
#   cd /opt/rusgame && npx web-push generate-vapid-keys
# Скопируйте Public Key и Private Key в строки ниже.
# VAPID_SUBJECT — ваш email (требование протокола Web Push, письма не шлёт).
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:ваш@email.ru
